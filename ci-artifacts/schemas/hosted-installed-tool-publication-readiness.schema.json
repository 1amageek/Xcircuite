{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/1amageek/Xcircuite/ci-artifacts/schemas/hosted-installed-tool-publication-readiness.schema.json",
  "title": "Hosted Installed Tool Publication Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "status", "generatedAt", "toolchainManifestSHA256", "lanes", "diagnostics"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "hosted-installed-tool-publication-readiness" },
    "status": { "enum": ["passed", "blocked"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "toolchainManifestSHA256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane", "status", "evidence"],
        "properties": {
          "lane": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "blocked"] },
          "evidence": { "type": ["string", "null"] },
          "package": { "type": "object" },
          "toolchainManifestSHA256": { "type": ["string", "null"] },
          "designInputSHA256": { "type": ["string", "null"] },
          "qualifiedCornerIDs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "reason", "suggestedAction"]
      }
    }
  }
}
