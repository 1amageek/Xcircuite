library (tt) {
  time_unit : "1ns";
  voltage_unit : "1V";
  delay_model : table_lookup;
  cell (nmos) {
    area : 1.0;
    pin (D) {
      direction : output;
      timing () {
        related_pin : "G";
        timing_type : combinational;
        cell_rise (scalar) {
          values ("0.1");
        }
      }
    }
  }
}
